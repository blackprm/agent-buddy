
# ═══════════════════════════════════════════════════════════════
# MyAgent 通用配置
# ═══════════════════════════════════════════════════════════════
# 复制此文件为 .env，填入你的 API Key 即可接入真实模型。
# cp .env.example .env

# ── 模型提供商选择 ──────────────────────────────────────────
# 可选值: codex | ark | openai | anthropic | deepseek | gateway | fake | fake_tool
# 不设置时自动检测：有 CODEX_API_KEY/CODEX_BASE_URL → codex，有 ARK_API_KEY → ark，有 OPENAI_API_KEY → openai，有 ANTHROPIC_API_KEY → anthropic，否则 → fake
# AGENT_MODEL_PROVIDER=ark

# ── 火山方舟 / ARK (doubao) ─────────────────────────────────
# 在 https://console.volcengine.com/ark 获取
ARK_API_KEY=your_ark_api_key_here
MODEL_ID=ep-20260530151501-dfqx6
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 图片理解 / 多模态模型（OpenAI-compatible Vision）────────────
# 豆包/方舟视觉模型可只配置模型和 base_url，默认复用 ARK_API_KEY
# AGENT_VISION_MODEL=ep-20260513103751-6d9f9
# AGENT_VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# AGENT_VISION_API_KEY=your_optional_dedicated_vision_api_key

# ── 图片生成 / 编辑（GPT Image Playground 能力内化）──────────────
# OpenAI-compatible Images API / Responses API；默认复用当前 provider 的 API Key/Base URL。
# Codex CLI 兼容模式会给 prompt 加防改写前缀，并跳过不兼容的 quality 参数。
# AGENT_IMAGE_MODEL=gpt-image-2
# AGENT_IMAGE_BASE_URL=https://api.openai.com/v1
# AGENT_IMAGE_API_KEY=your_optional_dedicated_image_api_key
# AGENT_IMAGE_API_MODE=images  # images | responses
# AGENT_IMAGE_CODEX_CLI=false

# ── 火山 CDP SaaS TOP 网关生图（CreateImageTask/GetImageTaskStatus）────
# 支持 TOP HMAC-SHA256 与 VolSign(OpenAPI SigV4) 双签名，作为独立生图工具 provider，不影响主聊天模型。
# AGENT_IMAGE_PROVIDER=top_aidp
# TOP_AIDP_BASE_URL=https://your-top-gateway.example.com/router/rest
# TOP_AIDP_APP_KEY=your_top_app_key
# TOP_AIDP_APP_SECRET=your_top_app_secret
# TOP_AIDP_MODEL=your_aidp_image_model_or_req_key
# TOP_AIDP_TOKEN=your_aidp_image_token
# TOP_AIDP_SIGNATURE_PROTOCOL=top  # top | volsign
# VolSign/OpenAPI 模式通常使用：https://open.volcengineapi.com
# TOP_AIDP_VOLC_SERVICE=cdp_saas
# TOP_AIDP_VOLC_REGION=cn-beijing
# TOP_AIDP_CREATE_METHOD=CreateImageTask
# TOP_AIDP_STATUS_METHOD=GetImageTaskStatus
# TOP_AIDP_VERSION=2.0  # VolSign/OpenAPI 模式一般是 2022-08-01，按冒烟脚本为准
# TOP_AIDP_POLL_INTERVAL=2
# TOP_AIDP_MAX_POLLS=90
# 编辑图会把参考图以内联 base64 传给 AIDP；为避免 400 / payload too large，会先压缩超限输入图。
# AGENT_IMAGE_EDIT_MAX_INPUT_BYTES=4194304
# AGENT_IMAGE_EDIT_MAX_INPUT_DIMENSION=2048
# AGENT_IMAGE_EDIT_JPEG_QUALITY=85

# ── 视频生成 / 编辑（AI 视频创意增强 API）──────────────────────
# Bearer Token 认证，接入《AI视频创意增强API使用说明》：
# - GenerateVideo: POST /create + GET /status/<task_id> 轮询，结果保存为 video attachment
# - VideoApi: prompt-rewrite、cancel、tasks、usage、assets/groups、assets、validate-session/result
# AGENT_VIDEO_BASE_URL=https://your-video-api.example.com
# AGENT_VIDEO_TOKEN=your_video_bearer_token
# AGENT_VIDEO_TIMEOUT=30
# AGENT_VIDEO_POLL_INTERVAL=10
# AGENT_VIDEO_MAX_POLLS=120  # 10s * 120 = 20min for long video tasks
# Local image/video/audio attachments used as GenerateVideo references are uploaded to TOS
# and passed to the video API as temporary signed URLs. AGENT_TOS_* aliases are supported.
# TOS_AK=your_tos_access_key
# TOS_SK=your_tos_secret_key
# TOS_BUCKET=your_tos_bucket
# TOS_ENDPOINT=tos-cn-beijing.volces.com
# TOS_REGION=cn-beijing
# TOS_SIGN_EXPIRES=86400

# ── 创意知识库 V3 检索（CreativeKBSearchV3 工具）──────────────
# 默认会从 /Users/bytedance/Desktop/.env 读取 Viking KB 凭证；服务部署时建议显式配置。
# AGENT_CREATIVE_KB_ENV_FILE=/Users/bytedance/Desktop/.env
# AGENT_CREATIVE_KB_V3_SOURCE_DIR=/Users/bytedance/PycharmProjects/empty/按照现在的故事板模式优化/seedance_vefaas
# VOLC_ACCESS_KEY=your_volc_access_key
# VOLC_SECRET_KEY=your_volc_secret_key
# VOLC_REGION=cn-beijing
# AD_CREATIVE_KB_COLLECTION=ad_creative_kb
# AD_CREATIVE_KB_PROJECT=default
# AD_CREATIVE_KB_RESOURCE_ID=
# HOT_V_CREATIVE_KB_DOMAIN=api-knowledgebase.mlp.cn-beijing.volces.com
# AGENT_CREATIVE_KB_V3_PER_ROUTE_LIMIT=8
# AGENT_CREATIVE_KB_V3_SELECTED_LIMIT=5

# ── codex-proxy 本地网关 ─────────────────────────────────────
# 先启动 https://github.com/icebear0828/codex-proxy ，并在 Dashboard 获取 API Key。
# codex provider 走 OpenAI-compatible Chat Completions: http://localhost:8080/v1/chat/completions
# AGENT_MODEL_PROVIDER=codex
# CODEX_API_KEY=your_codex_proxy_api_key
# CODEX_BASE_URL=http://localhost:8080/v1
# CODEX_MODEL=gpt-5.4
#
# 也支持复用官方 Codex CLI/Desktop 登录凭证：先运行 `codex login`，然后保持默认
# ${CODEX_HOME:-~/.codex}/auth.json；本服务会只读解析 tokens.access_token。
# 注意：auth.json 等同密码，不要提交或打印到日志。若 Codex 配置为 keyring 存储，
# 请改用 CODEX_ACCESS_TOKEN、CODEX_AUTH_JSON 或 CODEX_API_KEY 显式传入。
# CODEX_HOME=~/.codex
# CODEX_ACCESS_TOKEN=optional_non_interactive_token
# CODEX_AUTH_JSON=optional_full_auth_json_from_secret_manager

# ── OpenAI ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=

# ── DeepSeek ───────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-xxx
# MODEL_ID=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 通用 ───────────────────────────────────────────────────
# AGENT_SESSION_ID=my-session
# 模型流两次 delta 之间的 idle timeout，默认 120 秒；超长飞书文档任务可设为 43200（12h）或 0 禁用。
# AGENT_MODEL_STREAM_IDLE_TIMEOUT_SECONDS=120
# Full compact 摘要请求可单独配置；未设置时复用 AGENT_MODEL_STREAM_IDLE_TIMEOUT_SECONDS。
# AGENT_COMPACT_STREAM_IDLE_TIMEOUT_SECONDS=120
# 附件上传大小限制（图片/视频），默认 50MB
# AGENT_MAX_ATTACHMENT_BYTES=52428800
