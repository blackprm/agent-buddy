
# ═══════════════════════════════════════════════════════════════
# MyAgent 通用配置
# ═══════════════════════════════════════════════════════════════
# 复制此文件为 .env，填入你的 API Key 即可接入真实模型。
# cp .env.example .env

# ── 模型提供商选择 ──────────────────────────────────────────
# 可选值: ark | openai | anthropic | deepseek | fake | fake_tool
# 不设置时自动检测：有 ARK_API_KEY → ark，有 ANTHROPIC_API_KEY → anthropic，否则 → fake
# AGENT_MODEL_PROVIDER=ark

# ── 火山方舟 / ARK (doubao) ─────────────────────────────────
# 在 https://console.volcengine.com/ark 获取
ARK_API_KEY=your_ark_api_key_here
MODEL_ID=ep-20260530151501-dfqx6
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── OpenAI ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=

# ── DeepSeek ───────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-xxx
# MODEL_ID=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 通用 ───────────────────────────────────────────────────
# AGENT_SESSION_ID=my-session
