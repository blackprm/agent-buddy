# 火山方舟 API Key (在 https://console.volcengine.com/ark 获取)
ARK_API_KEY=your_api_key_here

# 模型接入点 ID 或模型名
# 例: ep-2024xxxxxx-xxxxx (你自己创建的接入点)
# 或: doubao-seed-1-6-250615 (官方模型 ID, 部分 region 直接可用)
MODEL_ID=doubao-seed-1-6-250615

# 可选: 自定义 base URL (默认北京区: https://ark.cn-beijing.volces.com/api/v3)
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
